<svg width="128" height="32" xmlns="http://www.w3.org/2000/svg">
  <!-- Idle frame -->
  <g id="idle">
    <!-- Body -->
    <rect x="4" y="8" width="8" height="12" fill="#3498db"/>
    <!-- Head -->
    <rect x="5" y="4" width="6" height="6" fill="#f39c12"/>
    <!-- Eyes -->
    <rect x="6" y="6" width="1" height="1" fill="#2c3e50"/>
    <rect x="9" y="6" width="1" height="1" fill="#2c3e50"/>
    <!-- Legs -->
    <rect x="5" y="20" width="2" height="4" fill="#2c3e50"/>
    <rect x="9" y="20" width="2" height="4" fill="#2c3e50"/>
    <!-- Arms -->
    <rect x="3" y="10" width="2" height="4" fill="#f39c12"/>
    <rect x="11" y="10" width="2" height="4" fill="#f39c12"/>
  </g>

  <!-- Walk frame 1 -->
  <g id="walk1" transform="translate(32, 0)">
    <!-- Body -->
    <rect x="4" y="8" width="8" height="12" fill="#3498db"/>
    <!-- Head -->
    <rect x="5" y="4" width="6" height="6" fill="#f39c12"/>
    <!-- Eyes -->
    <rect x="6" y="6" width="1" height="1" fill="#2c3e50"/>
    <rect x="9" y="6" width="1" height="1" fill="#2c3e50"/>
    <!-- Legs - walking position -->
    <rect x="5" y="20" width="2" height="4" fill="#2c3e50"/>
    <rect x="10" y="21" width="2" height="3" fill="#2c3e50"/>
    <!-- Arms - swinging -->
    <rect x="2" y="11" width="2" height="4" fill="#f39c12"/>
    <rect x="12" y="9" width="2" height="4" fill="#f39c12"/>
  </g>

  <!-- Walk frame 2 -->
  <g id="walk2" transform="translate(64, 0)">
    <!-- Body -->
    <rect x="4" y="8" width="8" height="12" fill="#3498db"/>
    <!-- Head -->
    <rect x="5" y="4" width="6" height="6" fill="#f39c12"/>
    <!-- Eyes -->
    <rect x="6" y="6" width="1" height="1" fill="#2c3e50"/>
    <rect x="9" y="6" width="1" height="1" fill="#2c3e50"/>
    <!-- Legs - opposite walking position -->
    <rect x="9" y="20" width="2" height="4" fill="#2c3e50"/>
    <rect x="4" y="21" width="2" height="3" fill="#2c3e50"/>
    <!-- Arms - swinging opposite -->
    <rect x="12" y="11" width="2" height="4" fill="#f39c12"/>
    <rect x="2" y="9" width="2" height="4" fill="#f39c12"/>
  </g>

  <!-- Jump frame -->
  <g id="jump" transform="translate(96, 0)">
    <!-- Body -->
    <rect x="4" y="8" width="8" height="12" fill="#3498db"/>
    <!-- Head -->
    <rect x="5" y="4" width="6" height="6" fill="#f39c12"/>
    <!-- Eyes -->
    <rect x="6" y="6" width="1" height="1" fill="#2c3e50"/>
    <rect x="9" y="6" width="1" height="1" fill="#2c3e50"/>
    <!-- Legs - tucked -->
    <rect x="5" y="20" width="2" height="3" fill="#2c3e50"/>
    <rect x="9" y="20" width="2" height="3" fill="#2c3e50"/>
    <!-- Arms - raised -->
    <rect x="2" y="8" width="2" height="4" fill="#f39c12"/>
    <rect x="12" y="8" width="2" height="4" fill="#f39c12"/>
  </g>
</svg>